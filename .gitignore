# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (모든 시크릿은 env var로만 관리, 코드에 쓰지 말 것)
.env*
!.env.example

# GAS 레거시 참조 (키 하드코딩 위험 — 로컬에서만 유지, 절대 커밋 금지)
legacy-gas/
_legacy-gas-backup/
**/Constants.gs
*.secrets.*
*.secret

# output logs (git tracked structure, not content)
output/logs/*.jsonl

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

.vercel
