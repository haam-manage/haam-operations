# ============================================================
# HAAM Operations — 환경변수 템플릿
# ============================================================
# 사용법: 이 파일을 .env.local 로 복사한 뒤 실제 값을 채운다.
# .env.local 은 .gitignore 에 의해 추적되지 않는다.
# ============================================================

# ----- Supabase -----
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
DATABASE_URL=

# ----- Toss Payments (test 또는 live 키) -----
NEXT_PUBLIC_TOSS_CLIENT_KEY=
TOSS_SECRET_KEY=
TOSS_WEBHOOK_SECRET=

# ----- Solapi (카카오 알림톡) -----
SOLAPI_API_KEY=
SOLAPI_API_SECRET=
SOLAPI_SENDER_NUMBER=
SOLAPI_PFID=

# ----- Telegram Bot A (관리자 알림봇) -----
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# ----- Google / Gemini -----
GOOGLE_SHEETS_ID=
GEMINI_API_KEY=

# ----- Admin 대시보드 Basic Auth (/dashboard, /contracts, /api/admin/*) -----
ADMIN_USER=
ADMIN_PASSWORD=
