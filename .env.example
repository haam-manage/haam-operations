# ============================================================
# HAAM Operations — 환경변수 템플릿
# ============================================================
# 사용법: 이 파일을 .env.local 로 복사한 뒤 실제 값을 채운다.
# .env.local 은 .gitignore 에 의해 추적되지 않는다.
# ============================================================

# ----- Supabase -----
# 앱은 Drizzle + postgres-js 로 DATABASE_URL 에 직접 연결한다.
# Supabase JS SDK 는 사용하지 않으므로 ANON/SERVICE_ROLE 키는 배포 대상에 두지 않는다.
# (키가 꼭 필요해지는 기능이 생기면 그때 다시 추가)
DATABASE_URL=

# ----- Toss Payments (test 또는 live 키) -----
NEXT_PUBLIC_TOSS_CLIENT_KEY=
TOSS_SECRET_KEY=
TOSS_WEBHOOK_SECRET=

# ----- Solapi (카카오 알림톡) -----
SOLAPI_API_KEY=
SOLAPI_API_SECRET=
SOLAPI_SENDER_NUMBER=
SOLAPI_PFID=

# ----- Telegram Bot A (관리자 알림봇) -----
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# ----- Google / Gemini -----
GOOGLE_SHEETS_ID=
GEMINI_API_KEY=

# ----- Admin 대시보드 Basic Auth (/dashboard, /contracts, /api/admin/*) -----
ADMIN_USER=
ADMIN_PASSWORD=
